# Environment Configuration Template
# Copy to .env and fill in actual values

# App Settings
DEBUG=False
APP_NAME="Zwesta Trading System"

# Database (PostgreSQL) - Update with your credentials
DATABASE_URL=postgresql://postgres:SecurePassword123@localhost:5432/xm_trader
# For SQLite development: DATABASE_URL=sqlite:///./test.db

# JWT Secrets (Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MT5 Configuration (XM Trading Account)
MT5_ACCOUNT=136372035
MT5_PASSWORD=!3bhNjYy
MT5_SERVER=MetaQuotes-Demo
MT5_TIMEOUT=30

# Binance API (Optional - for crypto trading)
BINANCE_API_KEY=your-api-key
BINANCE_API_SECRET=your-api-secret

# Twilio (WhatsApp Notifications)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration (for reports, etc.)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# CORS Origins (allow these domains to access API)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Trading Bot Configuration
BOT_ENABLED=true
BOT_SCAN_INTERVAL=5
POSITION_SIZE_PERCENT=2
STOP_LOSS_POINTS=50
TAKE_PROFIT_PERCENT=1.5
CONSECUTIVE_LOSS_LIMIT=3
DAILY_LOSS_LIMIT=500

# Application Server Settings
API_HOST=0.0.0.0
API_PORT=8000
TIMEZONE=Africa/Johannesburg
LOG_LEVEL=INFO
