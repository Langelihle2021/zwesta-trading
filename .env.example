# ==================== ZWESTA TRADING BACKEND CONFIGURATION ====================
# Copy this file to .env and fill in your credentials

# ==================== ENVIRONMENT ====================
# Set to 'DEMO' for demo account or 'LIVE' for live trading
TRADING_ENV=DEMO

# ==================== API SECURITY ====================
# API Key for authenticating requests (required for all critical endpoints)
# Generate a strong key like: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your_generated_api_key_here_change_in_production

# ==================== LIVE MT5 ACCOUNT CREDENTIALS ====================
# Only needed when TRADING_ENV=LIVE
# Get these from your broker (XM, IC Markets, Saxo, etc.)

# Your live MetaTrader 5 account number
MT5_ACCOUNT=0

# Your live account password
MT5_PASSWORD=

# Your broker's MT5 server name
# Examples: XM.MT5, ICMarkets-Demo, Saxo-Live, etc.
MT5_SERVER=

# Path to your MT5 installation (optional, defaults to C:\Program Files\XM Global MT5)
MT5_PATH=C:\Program Files\XM Global MT5

# ==================== WITHDRAWAL CONFIGURATION ====================
# Minimum withdrawal amount in USD
WITHDRAWAL_MIN=10

# Maximum withdrawal amount in USD
WITHDRAWAL_MAX=50000

# Processing fee as percentage (1.0 = 1%)
WITHDRAWAL_FEE_PERCENT=1.0

# Processing days for withdrawals
WITHDRAWAL_DAYS=3

# Test mode max amount (applies when TRADING_ENV=DEMO)
WITHDRAWAL_TEST_MAX=50

# ==================== DEPLOYMENT NOTES ====================
# For local development:
#   1. Copy this file to .env
#   2. Set TRADING_ENV=DEMO
#   3. Run: python multi_broker_backend_updated.py

# For live trading:
#   1. Get LIVE MT5 credentials from your broker
#   2. Set TRADING_ENV=LIVE
#   3. Fill in MT5_ACCOUNT, MT5_PASSWORD, MT5_SERVER
#   4. Generate a strong API_KEY
#   5. Deploy to your VPS
#   6. Update Flutter app with the same API_KEY
#   7. Restart backend service

# ==================== SECURITY BEST PRACTICES ====================
# 1. NEVER commit .env file to git (add to .gitignore)
# 2. Use strong API_KEY (32+ characters)
# 3. Store .env securely on production server
# 4. Use environment variables, not hardcoded values
# 5. Restrict file permissions: chmod 600 .env
# 6. Rotate API keys periodically
# 7. Monitor withdrawal requests for fraud
