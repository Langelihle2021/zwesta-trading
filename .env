# ==================== WITHDRAWAL CONFIGURATION ====================
# Minimum withdrawal amount in USD
WITHDRAWAL_MIN=10

# Maximum withdrawal amount in USD
WITHDRAWAL_MAX=50000

# Processing fee as percentage (1.0 = 1%)
WITHDRAWAL_FEE_PERCENT=1.0

# Processing days for withdrawals
WITHDRAWAL_DAYS=3

# Test mode max amount (applies when ENVIRONMENT=DEMO)
WITHDRAWAL_TEST_MAX=50

# ==================== DEPLOYMENT ====================
# SUPPORTS: Exness, XM Global, Binance (DEMO/LIVE switchable via ENVIRONMENT variable)
#
# FOR DEMO MODE:
#   1. Set ENVIRONMENT=DEMO
#   2. EXNESS: Backend uses Account 298997455, Server: Exness-MT5Trial9
#   3. XM GLOBAL: Set XM_ACCOUNT/XM_PASSWORD for demo credentials in .env
#   4. BINANCE: Set BINANCE_DEMO_API_KEY/BINANCE_DEMO_API_SECRET (testnet credentials)
#   5. Run: python multi_broker_backend_updated.py
#   6. Check logs for: "[DEMO] Mode Active..." with account details
#
# FOR LIVE MODE:
#   1. Set ENVIRONMENT=LIVE
#   2. EXNESS: Update EXNESS_ACCOUNT and EXNESS_PASSWORD
#   3. XM GLOBAL: Update XM_ACCOUNT and XM_PASSWORD
#   4. BINANCE: Update BINANCE_API_KEY and BINANCE_API_SECRET
#   5. Run: python multi_broker_backend_updated.py
#   6. Check logs for: "[LIVE] Mode Active..." with account details
#   7. Verify trades appear in each broker's portal/terminal
#
# HOW TO VERIFY TRADES ARE EXECUTING:
#   EXNESS DEMO:
#     - Open Exness MT5 Demo terminal
#     - Go to: Terminal → Trade History tab
#     - Trades appear within 1-2 seconds of bot execution
#
#   EXNESS LIVE:
#     - Open Exness portal (my.exness.com/account) → Trade History
#     - Or Exness MT5 Live terminal → Terminal → Trade History
#
#   XM GLOBAL DEMO:
#     - Open XM MT5 Demo terminal
#     - Go to: Terminal → Trade History tab
#
#   XM GLOBAL LIVE:
#     - Open XM portal or MT5 Live terminal
#     - Go to: Account History or Trade History
#
#   BINANCE DEMO:
#     - Open Binance Testnet (https://testnet.binance.vision)
#     - Go to: Wallet → Trade History or Orders
#
#   BINANCE LIVE:
#     - Open Binance.com
#     - Go to: Wallet → Trade History or Orders
#
# TROUBLESHOOTING:
#   - No trades appearing? Check backend logs for connection errors
#   - Wrong broker? Verify ENVIRONMENT matches which broker credentials you provided
#   - Check that MT5/API credentials are still valid (sometimes passwords expire)
#   - Ensure ENVIRONMENT=LIVE uses the LIVE credentials, not DEMO
#
# Generated: 2026-03-20
# Status: Multi-Broker DEMO/LIVE Support (Exness, XM Global, Binance)

# ==================== BOT PERSISTENCE & AUTO-RESTART ====================
# Enable automatic bot restart on backend startup
# Set to 'true' for persistent trading (bots resume after backend restart)
# Set to 'false' to start with no bots running
AUTO_RESTART_BOTS_ON_STARTUP=true

# ==================== WORKER POOL SCALING (100+ Users) ====================
# Number of worker subprocesses. Each worker gets its own MT5 terminal.
# 0 = disabled (legacy single-process mode, default)
# 3 = 3 workers x 35 bots/worker = 105 concurrent bots
# 5 = 5 workers x 35 bots/worker = 175 concurrent bots
WORKER_COUNT=3
MAX_BOTS_PER_WORKER=35

# ==================== REST TRADING (Phase 2 - 500+ Users) ====================
# MetaAPI: Cloud-hosted MT5 REST API — trades via HTTP instead of local MT5 terminal
# Sign up at https://metaapi.cloud — free tier: 1 account, paid: unlimited
# This is what eliminates the MT5 single-process bottleneck
METAAPI_TOKEN=
METAAPI_REGION=new-york

# Prefer REST trading for supported brokers (Exness, XM, PXBT)
# When true + MetaAPI token set: bots use REST API instead of local MT5
# When false or no token: falls back to local MT5 terminal (legacy mode)
PREFER_REST_TRADING=true

# ==================== REST PRICE FEED (Optional - reduces MT5 load) ====================
# Provides real-time prices via REST APIs instead of MT5 symbol_info_tick()
# Get free keys: https://twelvedata.com (800 req/day free) or https://alphavantage.co (25 req/day free)
# If both empty, prices come from MT5 terminal (still works, just slower)
TWELVE_DATA_KEY=
ALPHA_VANTAGE_KEY=

# ==================== SELF-HOSTED SOCKET BRIDGE (Free - No External Service) ====================
# Each MT5 terminal runs ZwestaTradeServer.mq5 EA on a unique port.
# Python backend sends trade commands via TCP socket to localhost.
# Format: broker:account:port,broker:account:port,...
# Example: Exness:298997455:8001,PXBT:1226483:8002
# Leave empty to disable (falls back to direct MT5 Python module)
SOCKET_BRIDGES=
# Auth token must match the EA's AuthToken input parameter
SOCKET_AUTH_TOKEN=zwesta

